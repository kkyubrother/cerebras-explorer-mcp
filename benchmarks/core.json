{
  "name": "core-readonly-exploration",
  "description": "Representative benchmark queries for cerebras-explorer on its own codebase.",
  "defaultPassScore": 0.72,
  "cases": [
    {
      "id": "explain-request-handler",
      "description": "Explain the MCP request handler factory.",
      "tool": "explain_symbol",
      "args": {
        "symbol": "createMcpRequestHandler",
        "language": "ko"
      },
      "expectations": [
        {
          "label": "Answer identifies the symbol and its handler role",
          "source": "answer",
          "groups": [
            ["createMcpRequestHandler"],
            ["mcp"],
            ["request handler", "요청 핸들러"],
            ["handleRequest", "handleNotification"]
          ],
          "weight": 0.45
        },
        {
          "label": "Answer mentions handled MCP methods",
          "source": "combined_text",
          "groups": [
            ["initialize"],
            ["tools/list"],
            ["tools/call"]
          ],
          "weight": 0.2
        },
        {
          "label": "Evidence cites implementation and tests",
          "source": "evidence_paths",
          "groups": [
            ["src/mcp/server.mjs"],
            ["tests/mcp-server.test.mjs"]
          ],
          "weight": 0.25
        },
        {
          "label": "Candidate paths include the implementation file",
          "source": "candidate_paths",
          "groups": [
            ["src/mcp/server.mjs"]
          ],
          "weight": 0.1
        }
      ],
      "checks": [
        {
          "label": "Returns at least two grounded evidence items",
          "type": "min_grounded_evidence_count",
          "value": 2,
          "weight": 0.1
        }
      ]
    },
    {
      "id": "trace-index-dependency",
      "description": "Trace the dependency chain from the process entry point.",
      "tool": "trace_dependency",
      "args": {
        "entryPoint": "src/index.mjs",
        "direction": "downstream",
        "maxDepth": 3,
        "language": "ko"
      },
      "expectations": [
        {
          "label": "Answer includes the entry point and server module",
          "source": "combined_text",
          "groups": [
            ["src/index.mjs"],
            ["src/mcp/server.mjs"],
            ["startMcpServer"]
          ],
          "weight": 0.35
        },
        {
          "label": "Answer includes key downstream runtime modules",
          "source": "combined_text",
          "groups": [
            ["src/explorer/runtime.mjs"],
            ["src/explorer/config.mjs"],
            ["src/mcp/jsonrpc-stdio.mjs"]
          ],
          "weight": 0.25
        },
        {
          "label": "Evidence covers the top-level import chain",
          "source": "evidence_paths",
          "groups": [
            ["src/index.mjs"],
            ["src/mcp/server.mjs"]
          ],
          "weight": 0.25
        },
        {
          "label": "Candidate paths include runtime internals",
          "source": "candidate_paths",
          "groups": [
            ["src/explorer/runtime.mjs"],
            ["src/explorer/providers/index.mjs"]
          ],
          "weight": 0.15
        }
      ],
      "checks": [
        {
          "label": "Returns at least two grounded evidence items",
          "type": "min_grounded_evidence_count",
          "value": 2,
          "weight": 0.1
        }
      ]
    },
    {
      "id": "session-context-flow",
      "description": "Trace how session state is stored and injected into later calls.",
      "tool": "explore_repo",
      "args": {
        "task": "세션 컨텍스트가 후속 explore 호출에 어떻게 재사용되는지 추적해라. 정의 위치, 저장되는 정보, 다음 호출에 주입되는 지점을 설명해라.",
        "scope": ["src/**", "tests/**"],
        "budget": "normal",
        "language": "ko",
        "hints": {
          "symbols": ["SessionStore", "globalSessionStore", "exploreRepository"],
          "strategy": "reference-chase"
        }
      },
      "expectations": [
        {
          "label": "Answer mentions the session store and later-call reuse",
          "source": "combined_text",
          "groups": [
            ["SessionStore", "sessionStore"],
            ["previousSummaries", "summaries", "이전 요약"],
            ["candidatePaths", "sessionCandidatePaths"],
            ["sessionStore.update", "update", "갱신"]
          ],
          "weight": 0.45
        },
        {
          "label": "Evidence covers runtime and session implementation files",
          "source": "evidence_paths",
          "groups": [
            ["src/explorer/runtime.mjs"],
            ["src/explorer/session.mjs"],
            ["src/mcp/server.mjs"]
          ],
          "weight": 0.35
        },
        {
          "label": "Candidate paths include the relevant tests",
          "source": "candidate_paths",
          "groups": [
            ["tests/runtime.mock.test.mjs"],
            ["tests/session.test.mjs"]
          ],
          "weight": 0.2
        }
      ],
      "checks": [
        {
          "label": "Returns at least three evidence items",
          "type": "min_evidence_count",
          "value": 3,
          "weight": 0.1
        },
        {
          "label": "Returns a session id in stats",
          "type": "has_session_id",
          "value": true,
          "weight": 0.05
        }
      ]
    },
    {
      "id": "similar-provider-patterns",
      "description": "Find modules that implement the provider abstraction pattern.",
      "tool": "find_similar_code",
      "args": {
        "reference": "src/explorer/providers/openai-compat.mjs",
        "scope": ["src/explorer/providers/**"],
        "language": "ko",
        "context": "같은 provider abstraction 패턴을 따르는 구현 파일을 찾아라."
      },
      "expectations": [
        {
          "label": "Answer names the provider implementation files",
          "source": "combined_text",
          "groups": [
            ["abstract.mjs"],
            ["openai-compat.mjs"],
            ["ollama.mjs"],
            ["failover.mjs"]
          ],
          "weight": 0.45
        },
        {
          "label": "Answer mentions the shared abstraction",
          "source": "combined_text",
          "groups": [
            ["AbstractChatClient"],
            ["createChatCompletion"],
            ["model getter", "model"]
          ],
          "weight": 0.25
        },
        {
          "label": "Evidence covers at least three provider files",
          "source": "evidence_paths",
          "groups": [
            ["src/explorer/providers/abstract.mjs"],
            ["src/explorer/providers/openai-compat.mjs"],
            ["src/explorer/providers/ollama.mjs"],
            ["src/explorer/providers/failover.mjs"]
          ],
          "weight": 0.3,
          "minCoverage": 0.75
        }
      ],
      "checks": [
        {
          "label": "Returns at least four grounded evidence items",
          "type": "min_grounded_evidence_count",
          "value": 4,
          "weight": 0.1
        }
      ]
    },
    {
      "id": "git-blame-guided-trace",
      "description": "Trace recent session changes using blame-guided strategy.",
      "tool": "explore_repo",
      "args": {
        "task": "SessionStore에 최근 추가된 validateForReuse 메서드의 도입 배경과 동작을 설명해라. git blame과 diff를 활용해라.",
        "scope": ["src/explorer/**", "tests/**"],
        "budget": "normal",
        "language": "ko",
        "hints": {
          "symbols": ["validateForReuse", "SessionStore"],
          "strategy": "blame-guided"
        }
      },
      "expectations": [
        {
          "label": "Answer explains validateForReuse purpose and behavior",
          "source": "combined_text",
          "groups": [
            ["validateForReuse"],
            ["SessionStore"],
            ["exhausted", "expired", "repo_mismatch", "invalid"]
          ],
          "weight": 0.45
        },
        {
          "label": "Evidence cites session.mjs implementation",
          "source": "evidence_paths",
          "groups": [
            ["src/explorer/session.mjs"]
          ],
          "weight": 0.3
        },
        {
          "label": "Candidate paths include tests",
          "source": "candidate_paths",
          "groups": [
            ["tests/session.test.mjs"]
          ],
          "weight": 0.15
        }
      ],
      "checks": [
        {
          "label": "Returns at least two grounded evidence items",
          "type": "min_grounded_evidence_count",
          "value": 2,
          "weight": 0.1
        }
      ]
    },
    {
      "id": "confidence-pipeline",
      "description": "Trace how evidence grounding and confidence scoring are computed.",
      "tool": "explore_repo",
      "args": {
        "task": "confidenceScore와 evidence 정규화가 어디서 계산되고, runtime이 어떤 입력을 넘기는지 추적해라. 계산 함수, 호출 지점, 후처리 흐름을 설명해라.",
        "scope": ["src/**", "tests/**"],
        "budget": "normal",
        "language": "ko",
        "hints": {
          "symbols": ["computeConfidenceScore", "normalizeExploreResult", "exploreRepository", "ExplorerRuntime"],
          "strategy": "symbol-first"
        }
      },
      "expectations": [
        {
          "label": "Answer mentions normalization, grounding, and scoring flow",
          "source": "combined_text",
          "groups": [
            ["normalizeExploreResult"],
            ["computeConfidenceScore"],
            ["checkEvidenceGrounding", "grounding"],
            ["observedRanges"],
            ["exploreRepository", "ExplorerRuntime"]
          ],
          "weight": 0.55
        },
        {
          "label": "Evidence cites runtime and schema files",
          "source": "evidence_paths",
          "groups": [
            ["src/explorer/runtime.mjs"],
            ["src/explorer/schemas.mjs"]
          ],
          "weight": 0.3
        },
        {
          "label": "Candidate paths surface verification tests",
          "source": "candidate_paths",
          "groups": [
            ["tests/runtime.mock.test.mjs"],
            ["tests/project-config.test.mjs"]
          ],
          "weight": 0.15
        }
      ],
      "checks": [
        {
          "label": "Returns at least four grounded evidence items",
          "type": "min_grounded_evidence_count",
          "value": 4,
          "weight": 0.1
        }
      ]
    }
  ]
}
