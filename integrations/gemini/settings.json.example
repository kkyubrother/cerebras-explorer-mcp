{
  "mcpServers": {
    "cerebras-explorer": {
      "command": "npx",
      "args": ["-y", "github:kkyubrother/cerebras-explorer-mcp#v0.1.0"],
      "env": {
        "CEREBRAS_API_KEY": "$CEREBRAS_API_KEY"
      },
      "trust": false,
      "includeTools": [
        "explore_repo",
        "find_relevant_code",
        "trace_symbol",
        "map_change_impact"
      ],
      "timeout": 60000
    }
  }
}
