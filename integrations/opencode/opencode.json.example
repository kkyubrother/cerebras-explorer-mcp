{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "cerebras-explorer": {
      "type": "local",
      "command": ["npx", "-y", "github:kkyubrother/cerebras-explorer-mcp"],
      "enabled": true,
      "environment": {
        "CEREBRAS_API_KEY": "${CEREBRAS_API_KEY}"
      }
    }
  }
}
